# Example environment variables for running the E2E examples and scripts.
# Copy this file to `.env` and adjust values as needed.

# -------------------------------------------------------------------
# Actions server (all examples use this)
# -------------------------------------------------------------------
# Base URL for your running actions-server.
# Local dev default is fine if you run it on 8787.
ARTHA_ACTIONS_BASEURL=http://localhost:8787

# Optional: Bearer token if your server requires auth. Leave empty otherwise.
ARTHA_ACTIONS_APIKEY=

# -------------------------------------------------------------------
# Wallets and asset (used by HTTP, Postman, and Notebook)
# -------------------------------------------------------------------
# Public keys for a buyer and seller test wallet.
# Use devnet/test keys. Do not paste real secrets into these examples.
ARTHA_BUYER_PUBKEY=BuyerWalletPublicKeyHere
ARTHA_SELLER_PUBKEY=SellerWalletPublicKeyHere

# Logical asset symbol. Your server maps this to a mint.
ARTHA_MINT=USDC

# Human amount (server converts to base units).
ARTHA_AMOUNT=1.0

# ISO 8601 delivery deadline and dispute window
ARTHA_DELIVERY_BY=2025-11-30T23:59:59Z
ARTHA_DISPUTE_HOURS=48

# -------------------------------------------------------------------
# ResolveTicket script (example/scripts/resolve_via_ticket.mjs)
# -------------------------------------------------------------------
# These mirror the variables the script reads. You can keep both ARTHA_* and
# the script-specific names in the same file; the script only reads the ones it needs.

# Actions base URL and API key in the script’s naming
BASE_URL=http://localhost:8787
API_KEY=

# The deal you want to resolve (paste from initiate response)
DEAL_ID=D-REPLACE-ME

# Suggested action for the ticket: RELEASE or REFUND
ACTION=RELEASE

# Optional split in basis points (0..10000). 0 means full to the chosen side.
SPLIT_BPS=0

# Optional CID that points to rationale/evidence stored on IPFS/Arweave
RATIONALE_CID=bafyREPLACE-RATIONALE

# Confidence in [0,1]. Purely informational for your verifier.
CONFIDENCE=0.9

# Ticket expiry TTL in seconds from now
EXPIRES_IN_SEC=3600

# Ed25519 keys for ticket signing (hex or base64). Use throwaway dev keys.
# WARNING: Never commit real secrets. This is for local/dev only.
TICKET_SECRET=
TICKET_PUBLIC_KEY=

# -------------------------------------------------------------------
# Optional: cluster or logging toggles used by your server (if any)
# -------------------------------------------------------------------
# EXAMPLES_CLUSTER=devnet
# LOG_LEVEL=info
